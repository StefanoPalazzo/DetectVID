# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno para DetectVID Backend
# NUNCA commitear este archivo — está en .gitignore
# Copiar como .env y completar los valores reales
# ─────────────────────────────────────────────────────────────────────────────

# Base de datos PostgreSQL
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_DB
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/detectvid_db"

# JWT — secret largo y aleatorio (mínimo 32 caracteres)
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REEMPLAZAR_CON_UN_SECRET_LARGO_Y_ALEATORIO"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3001
NODE_ENV="development"

# CORS — origen del frontend (Vite corre en 5173 por defecto)
FRONTEND_URL="http://localhost:5173"

# ── Storage ───────────────────────────────────────────────────────────────────
# Proveedor de almacenamiento de imágenes
# Opciones: "cloudinary" | "local" | "s3" (futuro) | "gcs" (futuro)
STORAGE_PROVIDER="cloudinary"

# Cloudinary — https://cloudinary.com (cuenta gratuita disponible)
CLOUDINARY_CLOUD_NAME="tu_cloud_name"
CLOUDINARY_API_KEY="tu_api_key"
CLOUDINARY_API_SECRET="tu_api_secret"

# Local storage (solo si STORAGE_PROVIDER=local)
# LOCAL_STORAGE_PATH="./uploads"
# LOCAL_STORAGE_URL="http://localhost:3001"
